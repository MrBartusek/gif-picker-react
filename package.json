{
  "name": "gif-picker-react",
  "description": "Tenor Gif Picker for React",
  "version": "1.5.0",
  "author": "MrBartusek <bartosz@dokurno.dev>",
  "license": "MIT",
  "keywords": [
    "react",
    "tenor",
    "gif"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrBartusek/gif-picker-react.git"
  },
  "homepage": "https://dokurno.dev/gif-picker-react",
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup",
    "storybook": "storybook dev -p 6006",
    "lint": "eslint src",
    "lint:fix": "npm run lint -- --fix",
    "version": "npm run build",
    "update-example": "npm install && cd example && npm update gif-picker-react && npm install && cd .."
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-links": "10.4.0",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
    "@storybook/react-webpack5": "10.4.0",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.2",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "10.4.0",
    "postcss": "^8.5.15",
    "postcss-inline-svg": "^6.0.0",
    "postcss-svgo": "^7.1.0",
    "prettier": "3.8.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "10.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  }
}
